{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev src/index.ts",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply subserver-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply subserver-db --remote"
  },
  "dependencies": {
    "hono": "^4.4.7",
    "drizzle-orm": "^0.31.4",
    "zod": "^3.23.8",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "drizzle-kit": "^0.22.7",
    "typescript": "^5.4.5",
    "wrangler": "^3.60.3"
  }
}
